# Font
font-family = JetBrains Mono
font-size = 15

# Appearance
theme = Catppuccin Frappe
background-blur-radius = 20
cursor-style = block
shell-integration-features = no-cursor

# Brighten ANSI bright black (color 8) so dim text from CLI tools
# (Claude Code's tool previews, git's hint text, etc.) is legible
# against Frappé's base background. Default Frappé is Surface2
# (#626880) — switching to Overlay0 (#737994) lifts contrast without
# leaving the Catppuccin palette.
palette = 8=#737994

# Window
window-decoration = true
window-inherit-working-directory = true
macos-non-native-fullscreen = visible-menu

# Input
macos-option-as-alt = true
mouse-hide-while-typing = true

# Keybindings
keybind = shift+enter=text:\x1b\r
keybind = ctrl+shift+enter=new_split:right
keybind = ctrl+shift+o=new_split:down
keybind = ctrl+shift+bracket_left=goto_split:previous
keybind = ctrl+shift+bracket_right=goto_split:next
keybind = alt+t=new_tab
keybind = shift+alt+bracket_left=previous_tab
keybind = shift+alt+bracket_right=next_tab
